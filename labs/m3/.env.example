# M3 · vLLM CPU — copy to .env and tune. compose.yaml reads these.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Model preset (pick ONE). SmolLM2 family — small enough for a laptop CPU.
# ---------------------------------------------------------------------------
# Balanced default (~1.3 GB weights, ~4 GB RAM) — used in the lab.
MODEL_NAME=HuggingFaceTB/SmolLM2-360M-Instruct

# Lightest — for 8 GB machines or the fastest startup (~500 MB weights, ~2 GB RAM).
# MODEL_NAME=HuggingFaceTB/SmolLM2-135M-Instruct

# Highest quality — needs ~12 GB RAM; raise MEMORY_LIMIT below (~6.5 GB weights).
# MODEL_NAME=HuggingFaceTB/SmolLM2-1.7B-Instruct

# ---------------------------------------------------------------------------
# Serving knobs
# ---------------------------------------------------------------------------
DTYPE=auto
MAX_MODEL_LEN=2048       # context window; lower to 1024 to save memory
MAX_NUM_SEQS=8           # concurrent sequences the batcher packs together
KVCACHE_SPACE=1          # GB reserved for the KV cache

# ---------------------------------------------------------------------------
# CPU / thread tuning (see the lesson's CPU track)
# ---------------------------------------------------------------------------
OMP_THREADS=2            # main knob: OpenMP threads (try 4 on Apple Silicon)
CPU_LIMIT=4.0            # hard cap on cores the container may use
CPU_RESERVATION=2.0
MEMORY_LIMIT=8G          # hard cap on RAM
MEMORY_RESERVATION=4G

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
VLLM_PORT=8009           # host port (container always serves on 8000)
